<Page x:Class="LyricSync.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:LyricSync"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    <local:BoolToVisibilityConverter x:Key="InvertedBoolToVisibility" Invert="True" />
    <local:ColorMatchToThicknessConverter x:Key="SelectedColorThickness" />

    <Style x:Key="SettingLabelStyle"
           TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Opacity" Value="0.8" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SettingDividerStyle"
           TargetType="Border">
      <Setter Property="Height" Value="1" />
      <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
      <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style x:Key="ColorSwatchStyle"
           TargetType="Button">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderBrush" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
  </Page.Resources>

  <Grid Padding="20"
        RowSpacing="12"
        RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- Header -->
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="LyricSync"
                 FontSize="26"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Column="1"
                 Text="{Binding Playback.StatusText}"
                 Opacity="0.65"
                 FontSize="13"
                 VerticalAlignment="Center" />
    </Grid>

    <!-- Now playing -->
    <Border Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12">
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding Playback.Title}"
                   FontSize="17"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding Playback.Subtitle}"
                   FontSize="13"
                   Opacity="0.65"
                   TextWrapping="Wrap" />
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10"
              Margin="0,6,0,0">
          <TextBlock Text="{Binding Playback.PositionText}"
                     FontSize="12"
                     Opacity="0.65"
                     VerticalAlignment="Center" />
          <ProgressBar Grid.Column="1"
                       Value="{Binding Playback.Progress}"
                       Maximum="100"
                       VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Text="{Binding Playback.DurationText}"
                     FontSize="12"
                     Opacity="0.65"
                     VerticalAlignment="Center" />
        </Grid>
        <TextBlock Text="{Binding LyricsStatusText}"
                   FontSize="12"
                   Opacity="0.55" />
      </StackPanel>
    </Border>

    <!-- Overlay controls -->
    <Border Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12">
      <StackPanel>

        <!-- Overlay actions -->
        <Grid ColumnDefinitions="130,*"
              MinHeight="40">
          <TextBlock Text="Overlay"
                     Style="{StaticResource SettingLabelStyle}" />
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <Button Content="{Binding OverlayButtonText}"
                    Command="{Binding ToggleOverlay}"
                    Style="{ThemeResource AccentButtonStyle}" />
            <Button Content="{Binding MoveButtonText}"
                    Command="{Binding ToggleMoveOverlay}"
                    ToolTipService.ToolTip="Unlocks the overlay so you can drag it into place, then locks it click-through again." />
          </StackPanel>
        </Grid>

        <Border Style="{StaticResource SettingDividerStyle}" />

        <!-- Lyrics color -->
        <Grid ColumnDefinitions="130,*"
              MinHeight="40">
          <TextBlock Text="Lyrics color"
                     Style="{StaticResource SettingLabelStyle}" />
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
            <Button Background="#FFEB3B"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#FFEB3B"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#FFEB3B}"
                    ToolTipService.ToolTip="Subtitle yellow" />
            <Button Background="#FFFFFF"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#FFFFFF"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#FFFFFF}"
                    ToolTipService.ToolTip="White" />
            <Button Background="#1ED760"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#1ED760"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#1ED760}"
                    ToolTipService.ToolTip="Spotify green" />
            <Button Background="#4FC3F7"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#4FC3F7"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#4FC3F7}"
                    ToolTipService.ToolTip="Sky blue" />
            <Button Background="#FFA726"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#FFA726"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#FFA726}"
                    ToolTipService.ToolTip="Orange" />
            <Button Background="#F06292"
                    Style="{StaticResource ColorSwatchStyle}"
                    Command="{Binding SetLyricColor}"
                    CommandParameter="#F06292"
                    BorderThickness="{Binding LyricColor, Converter={StaticResource SelectedColorThickness}, ConverterParameter=#F06292}"
                    ToolTipService.ToolTip="Pink" />
          </StackPanel>
        </Grid>

        <Border Style="{StaticResource SettingDividerStyle}" />

        <!-- Background opacity -->
        <Grid ColumnDefinitions="130,*,44"
              ColumnSpacing="10"
              MinHeight="40">
          <TextBlock Text="Background opacity"
                     Style="{StaticResource SettingLabelStyle}" />
          <Slider Grid.Column="1"
                  Minimum="0"
                  Maximum="100"
                  StepFrequency="1"
                  VerticalAlignment="Center"
                  Value="{Binding BackgroundOpacity, Mode=TwoWay}"
                  ToolTipService.ToolTip="0% = lyrics float directly on screen, 100% = solid panel. Text always stays opaque." />
          <TextBlock Grid.Column="2"
                     Text="{Binding BackgroundOpacityLabel}"
                     FontSize="12"
                     Opacity="0.65"
                     TextAlignment="Right"
                     VerticalAlignment="Center" />
        </Grid>

        <Border Style="{StaticResource SettingDividerStyle}" />

        <!-- Lyrics size -->
        <Grid ColumnDefinitions="130,*,44"
              ColumnSpacing="10"
              MinHeight="40">
          <TextBlock Text="Lyrics size"
                     Style="{StaticResource SettingLabelStyle}" />
          <Slider Grid.Column="1"
                  Minimum="18"
                  Maximum="52"
                  StepFrequency="1"
                  VerticalAlignment="Center"
                  Value="{Binding FontSize, Mode=TwoWay}" />
          <TextBlock Grid.Column="2"
                     Text="{Binding FontSizeLabel}"
                     FontSize="12"
                     Opacity="0.65"
                     TextAlignment="Right"
                     VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Lyrics -->
    <Border Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="4">
      <Grid>
        <ListView x:Name="LyricsList"
                  ItemsSource="{Binding Lines}"
                  SelectionMode="Single"
                  IsItemClickEnabled="False"
                  Visibility="{Binding IsPlainLyricsVisible, Converter={StaticResource InvertedBoolToVisibility}}">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="MinHeight" Value="30" />
              <Setter Property="Padding" Value="12,2" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="46,*">
                <TextBlock Text="{Binding TimeText}"
                           FontSize="11"
                           Opacity="0.55"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Text}"
                           TextWrapping="Wrap" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <ScrollViewer Visibility="{Binding IsPlainLyricsVisible, Converter={StaticResource BoolToVisibility}}"
                      Padding="12,8">
          <TextBlock Text="{Binding PlainLyricsText}"
                     TextWrapping="Wrap" />
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Footer -->
    <TextBlock Grid.Row="4"
               Text="Built with Uno Platform + MVUX · Syncs with Spotify or any player via Windows · Lyrics from LRCLIB"
               FontSize="11"
               Opacity="0.45"
               HorizontalAlignment="Center" />
  </Grid>
</Page>
