<UserControl
    x:Class="LyricSync.OverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LyricSync">

  <UserControl.Resources>
    <local:HexColorToBrushConverter x:Key="HexBrush" />
  </UserControl.Resources>

  <!--
    Pure black (#FF000000) is the window's transparency key, so the root must paint black
    EXPLICITLY. A "Transparent"/unpainted root leaves the surface to be cleared to a color
    the GPU/driver chooses — black on some machines, white on others — and only black keys
    out, so on a "white-clear" GPU the overlay showed as a solid white box. Explicit black
    pixels key out on every GPU. RequestedTheme=Dark is belt-and-suspenders for any themed
    brush inside.
  -->
  <Grid Background="#FF000000"
        RequestedTheme="Dark">

    <!-- The translucent background panel is NOT here: it is a separate native layered
         window glued beneath this one (see OverlayController/Win32Overlay), because
         this window's transparency is color-keyed (binary) while the panel needs a
         real alpha gradient. -->

    <!-- Move-mode chrome: visible only while the overlay is unlocked for dragging.
         The faint background tint matters: it keeps the whole rectangle off the
         color key, so every pixel of the overlay is grabbable while moving. -->
    <Border CornerRadius="14"
            Background="#59101216"
            BorderBrush="#B01ED760"
            BorderThickness="2"
            IsHitTestVisible="False"
            Opacity="{Binding MoveChromeOpacity}">
      <TextBlock Text="Drag to position · click “Lock overlay” in LyricSync when done"
                 Foreground="#CCFFFFFF"
                 FontSize="12"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0,4,0,0" />
    </Border>

    <Grid RowDefinitions="Auto,*"
          Padding="26,12,26,16">

      <local:OutlinedText Text="{Binding Display.TrackLabel}"
                          Foreground="White"
                          Opacity="0.5"
                          FontSize="13"
                          MaxTextLines="1" />

      <StackPanel Grid.Row="1"
                  VerticalAlignment="Center"
                  Spacing="4">
        <StackPanel.RenderTransform>
          <TranslateTransform x:Name="LyricsTranslate" />
        </StackPanel.RenderTransform>

        <local:OutlinedText Text="{Binding Display.Previous}"
                            Foreground="White"
                            Opacity="0.38"
                            FontSize="{Binding SecondaryFontSize}"
                            MaxTextLines="1" />
        <local:OutlinedText Text="{Binding Display.Current}"
                            Foreground="{Binding LyricColor, Converter={StaticResource HexBrush}}"
                            FontWeight="Bold"
                            FontSize="{Binding FontSize}"
                            Wrapping="WrapWholeWords"
                            MaxTextLines="2" />
        <local:OutlinedText Text="{Binding Display.Next}"
                            Foreground="White"
                            Opacity="0.55"
                            FontSize="{Binding SecondaryFontSize}"
                            MaxTextLines="1" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
