<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<PublishProtocol>FileSystem</PublishProtocol>
		<Platform>x64</Platform>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<PublishDir>bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\publish\</PublishDir>
		<SelfContained>true</SelfContained>
		<!-- One shareable .exe: runtime + native libs bundled, extracted on first run. -->
		<PublishSingleFile>True</PublishSingleFile>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<!--
		  Compression is deliberately OFF. It would shrink the file (~165 MB → ~104 MB)
		  but forces every assembly to be decompressed into PRIVATE memory at startup
		  (~233 MB private vs ~85 MB). Uncompressed lets Windows memory-map the bundle as
		  shared, reclaimable pages, so the app's memory footprint stays roughly halved.
		  Disk is cheap; RAM is what the user watches — keep this false.
		-->
		<EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
		<!--
		  ReadyToRun is OFF. R2R precompiles native code for faster startup, but it nearly
		  DOUBLES the file (~165 MB → ~306 MB uncompressed) for zero RAM benefit (identical
		  ~85 MB private). For an .exe copied between machines, half the size is worth a
		  second of first-launch JIT. Turn back on only if startup latency becomes a concern.
		-->
		<PublishReadyToRun>False</PublishReadyToRun>
		<!-- Trimming stays off: the app relies on reflection-based {Binding} paths and
		     System.Text.Json reflection serialization (settings + LRCLIB responses). -->
		<PublishTrimmed>False</PublishTrimmed>
	</PropertyGroup>
</Project>
